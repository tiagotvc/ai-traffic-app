# Local Postgres
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_traffic?sslmode=disable"

# Supabase — pooler transacional (app)
# DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# Supabase — pooler sessão (migrations: pnpm run db:migrate)
# DIRECT_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require"

# Vercel: migrações só no build (vercel-build), não em cada cold start
# SKIP_RUNTIME_MIGRATIONS="1"

# Logs SQL do TypeORM no terminal (desligado por padrão — evita poluir o console do browser em dev)
# TYPEORM_LOGGING="1"

NEXTAUTH_URL="http://localhost:3008"
# Produção (Vercel): use o domínio público OU apague NEXTAUTH_URL/AUTH_URL (o app usa VERCEL_URL).
# NUNCA deixe localhost em produção — o OAuth do Facebook quebra.
# AUTH_URL="https://seu-dominio.vercel.app"
# Domínio canônico para OAuth Meta (se diferente do que o usuário acessa):
# META_OAUTH_REDIRECT_BASE_URL="https://seu-dominio.com"
# URL pública para o Puppeteer abrir /report-print na geração de PDF (produção com domínio customizado):
# REPORT_PRINT_BASE_URL="https://seu-dominio.com"
# AUTH_TRUST_HOST="true"
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET="change-me"
AUTH_SECRET="change-me"

# Meta (Facebook Login + Marketing API) — https://developers.facebook.com/apps/
# Obrigatório para "Conectar Meta". Sem isso o Facebook mostra "ID do app inválido".
META_APP_ID="1234567890123456"
META_APP_SECRET="sua-chave-secreta-do-app"
# Facebook Login for Business → Configurações → criar config (User access token)
# com permissão pages_show_list (não use só public_profile; não use email neste app).
# Copie o Configuration ID:
META_FACEBOOK_LOGIN_CONFIG_ID="1234567890123456"
# Config separada para Conectar Meta / ads (ads_read, ads_management, etc.) — opcional
# META_BUSINESS_OAUTH_CONFIG_ID="1234567890123456"
# Sem config_id, o app usa scope pages_show_list (fallback)
# META_FACEBOOK_LOGIN_SCOPES="pages_show_list"
# Facebook Login → Configurações → URI de redirecionamento OAuth válido (adicione TODOS os ambientes):
#   http://localhost:3008/api/auth/callback/facebook-login  (dev)
#   https://SEU-DOMINIO/api/auth/callback/facebook-login      (produção)
#   http://localhost:3008/api/meta/oauth/callback           (Meta Business / ads dev)
#   https://SEU-DOMINIO/api/meta/oauth/callback             (Meta Business / ads prod)
# Google OAuth (login + futuro Google Ads)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# Redirect URI login: http://localhost:3008/api/auth/callback/google
# Redirect URI Google Ads (stub): http://localhost:3008/api/google/oauth/callback
# Google Maps (Geo Scientist: POIs + cidade resolvida por pin). Ative Geocoding API + Places API.
# Sem esta key o enriquecimento Google é no-op (IBGE + geometria seguem funcionando).
# GOOGLE_MAPS_API_KEY=""
# Cache de criativos (segundos, padrão 300)
# CREATIVES_CACHE_TTL_SEC="300"
# Opcional — fallback se o cliente não tiver Página/URL próprias (prefira /clients/[slug] → Publicação na Meta)
META_PAGE_ID=""
META_LINK_URL="https://seusite.com.br"
# Token dedicado para Biblioteca de Anúncios (ads_archive) — Orion Brain / Mercado
# Usado em: src/lib/meta-ad-library/official-graph-provider.ts
# Fallback: META_SYSTEM_USER_TOKEN (System User do Business Manager)
#
# Como obter (desenvolvimento):
# 1. developers.facebook.com → seu App (mesmo META_APP_ID) → Ad Library API
#    → solicite acesso "Ad Library API" (pode exigir revisão do app).
# 2. Permissão mínima no token: ads_read
# 3. Opção A — User token de teste (dev rápido):
#    Graph API Explorer → app → ads_read → Generate Access Token
#    → copie para META_AD_LIBRARY_ACCESS_TOKEN (expira; renove no Explorer).
# 4. Opção B — System User (recomendado p/ staging/prod):
#    business.facebook.com → Configurações → Usuários do sistema → criar
#    → atribua o app → gere token com ads_read → META_SYSTEM_USER_TOKEN
# 5. UE/EEE: verificação de identidade do desenvolvedor pode ser obrigatória
#    (Meta → App Review / Identity verification) para ads_archive em países EU.
# 6. Reinicie o servidor após alterar .env.local (nunca commite o token).
# META_AD_LIBRARY_ACCESS_TOKEN=""
# META_SYSTEM_USER_TOKEN=""
#
# SearchAPI — Meta Ad Library (alternativa recomendada para dev / Orion Brain)
# Usado em: src/lib/meta-ad-library/searchapi-provider.ts (prioridade sobre Graph)
# Endpoint: GET https://www.searchapi.io/api/v1/search?engine=meta_ad_library
# Auth: Authorization: Bearer <SEARCHAPI_API_KEY> (ou ?api_key= na query)
# Params: q (keywords), page_id (concorrente), country (ex. BR), ad_type=all, active_status=active
# Docs: https://www.searchapi.io/docs/meta-ad-library-api
# Cursor MCP (opcional, IDE): claude mcp add orion_agency \
#   "https://www.searchapi.io/mcp?token=$SEARCHAPI_API_KEY" --transport http
# SEARCHAPI_API_KEY=""
# Economia do searchapi (cientistas): cache por nicho+país + teto mensal de chamadas.
# MARKET_RESEARCH_TTL_SEC="604800"   # 7 dias — 1 chamada por nicho serve todos os usuários nesse período
# SEARCHAPI_MONTHLY_BUDGET="90"      # teto/mês (margem sob o limite do plano free de 100). 0 = sem teto

# Gemini (Google AI Studio)
GEMINI_API_KEY=""
# gemini-2.0-flash foi descontinuado; use 2.5 para dev/prod
GEMINI_MODEL="gemini-2.5-flash-lite"
# Fallback automático em 429/503 (modelo primário + cadeia)
GEMINI_MODEL_FALLBACKS="gemini-2.5-flash-lite,gemini-2.5-flash"

# Claude (Anthropic) — públicos com IA no criador de campanhas
ANTHROPIC_API_KEY=""
# IDs na API (painel → nome amigável): claude-opus-4-8 (Opus 4.8), claude-sonnet-4-6 (Sonnet 4.6), claude-haiku-4-5 (Haiku 4.5)
ANTHROPIC_MODEL="claude-sonnet-4-6"

# Email (SendGrid)
SENDGRID_API_KEY=""
EMAIL_FROM="Traffic AI <no-reply@traffic-ai.local>"

# Cron local (opcional)
CRON_BASE_URL="http://localhost:3008"
CRON_SESSION_COOKIE=""

# Cache distribuído (produção) — opcional; sem isso usa cache in-memory por instância
# Opção A (recomendada na Vercel): Upstash REST
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN=""
# Opção B: Redis Cloud TCP — NÃO use REDIS_URL na Vercel (conexão TCP trava serverless).
# Local/dev apenas:
# REDIS_URL="redis://default:SENHA@host.db.redis.io:PORT"
# Na Vercel, se precisar TCP: REDIS_ALLOW_TCP_ON_VERCEL=1 (não recomendado)

# Benchmark de rotas Meta: node scripts/benchmark-meta-pages.mjs
# BENCHMARK_BASE_URL="http://localhost:3008"
# BENCHMARK_COOKIE="next-auth.session-token=..."
# BENCHMARK_CLIENT_SLUG="slug-do-cliente"

# Dados demo no dashboard (opcional; padrão desligado)
# DEMO_MODE="true"
# NEXT_PUBLIC_DEMO_MODE="true"

# Asaas (Brasil — PIX, cartão, NF)
# ASAAS_ENV="sandbox"
# ASAAS_API_KEY="\$aact_prod_..."  # OBRIGATÓRIO escapar o $ com \\ — chaves Asaas começam com $
# ASAAS_WEBHOOK_TOKEN=""  # token gerado ao criar webhook no painel Asaas
# URL do webhook em produção: https://SEU-DOMINIO/api/webhooks/asaas
# ASAAS_NF_SERVICE_CODE=""

# Stripe (internacional)
# STRIPE_SECRET_KEY=""
# STRIPE_PUBLISHABLE_KEY=""
# STRIPE_WEBHOOK_SECRET=""

# Super-admins que aprovam reembolsos (emails separados por vírgula)
# BILLING_ADMIN_EMAILS="admin@traffic-ai.local"

# Labs / Scientists Worker
# Em dev, LABS_MOCK=1 (padrão) simula o pipeline sem worker/Inngest
LABS_MOCK_MODE="1"
# Labs UI/API — desligado no MVP para usuários comuns; platform admins sempre têm acesso.
# Use NEXT_PUBLIC_LABS_ENABLED=1 para liberar para todos (rollout público).
# NEXT_PUBLIC_LABS_ENABLED="1"
SCIENTISTS_WORKER_URL="http://localhost:8080"
SCIENTISTS_WORKER_API_KEY="change-me"

# Inngest (dev: npx inngest-cli@latest dev)
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# Supabase REST (scientists-worker + opcional no app)
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

