{
  "name": "ai-traffic-app",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.4",
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3008",
    "prebuild": "node scripts/migrate-vercel.mjs",
    "build": "next build",
    "vercel-build": "node scripts/migrate-vercel.mjs && next build",
    "start": "next start -p 3008",
    "lint": "next lint",
    "db:migrate": "tsx src/db/run-migrations.ts",
    "db:up": "docker compose up -d",
    "user:create": "tsx scripts/create-user.ts tiago@traffic-ai.local TrafficAI2026! \"Tiago Carvalho\"",
    "sync:cron": "tsx scripts/sync-cron.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "dotenv": "latest",
    "next": "latest",
    "next-auth": "5.0.0-beta.29",
    "next-intl": "latest",
    "pdf-lib": "latest",
    "pg": "latest",
    "react": "latest",
    "react-dom": "latest",
    "recharts": "latest",
    "reflect-metadata": "latest",
    "server-only": "latest",
    "stripe": "^22.2.0",
    "typeorm": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "postcss": "latest",
    "tailwindcss": "^3.4.17",
    "ts-node": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
